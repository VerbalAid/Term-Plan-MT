# Copy to .env and fill in (do not commit .env)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=password

# If nothing is listening on 7687, start Neo4j:  docker compose up -d  (see docker-compose.yml)

