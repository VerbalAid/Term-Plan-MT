# Copy to .env and fill in (do not commit .env)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=password

# If nothing is listening on 7687, start Neo4j:  docker compose up -d  (see docker-compose.yml)

# Stage-3 planning weights (optional): PLAN_ALPHA PLAN_BETA PLAN_GAMMA

# MedDRA: password for the English/French .zip archives
# MEDDRA_ZIP_PASSWORD=

# Web app (webapp/README.md): pip install -r webapp/requirements.txt
# GROUND_FUZZY_CUTOFF=90
# LOOKUP_SEMANTIC_MIN=0.55
# PREWARM_SEMANTIC=false
