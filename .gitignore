# Local secrets (never commit)
.env
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Optional: large extracted MedDRA flat files
# data/meddra/MedAscii/
# data/meddra/ascii-290/

# Pipeline JSONL outputs (regenerate: tools/pipeline/run_pipeline.py, rerun_all.sh)
results/**/*.jsonl

# Local bulk / logs (regenerate or optional; shrink clones — see README §0)
archive/
# Prefer long-run logs under archive/logs/ (inside archive/, ignored with the rest).
logs/

# Unsloth JIT cache
unsloth_compiled_cache/

# Local / multi-GB checkpoints (see models/README.md)
models/*
!models/README.md

# MedDRA release and optional training corpora (obtain under licence; see data/README.md)
data/meddra/
data/QUAERO_FrenchMed/

# Large ontology NER SFT exports (regenerate; see tools/data/build_ontology_sft.py)
data/ontology_ner_full*.jsonl
data/ontology_ner_full*.jsonl.bak
data/sft/

# IDE / OS
.cursor/
.DS_Store

# Planning cache (local)
data/section48/planning_locks.json

# pdflatex intermediates (e.g. docs/termplan_acl_snapshot.tex)
*.aux
docs/**/*.log
docs/**/*.out

# Ad-hoc error-analysis run logs
error_analysis/*.log

# LaTeX build artefacts
*.aux
*.out
docs/paper/*.log
