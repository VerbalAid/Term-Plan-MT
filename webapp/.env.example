# MedDRA Lookup Tool — copy to webapp/.env or repo-root .env

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=password

# Fuzzy match minimum (0–100)
GROUND_FUZZY_CUTOFF=90

# Semantic cosine floor (0–1)
LOOKUP_SEMANTIC_MIN=0.55

# Lightweight multilingual model (Render-friendly)
TERMPLAN_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# false = lazy-load embeddings on first semantic query (recommended on Render)
PREWARM_SEMANTIC=false
