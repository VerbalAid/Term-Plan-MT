# MedDRA Lookup Tool — copy to webapp/.env or repo-root .env

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=password

GROUND_FUZZY_CUTOFF=90
LOOKUP_SEMANTIC_MIN=0.55
TERMPLAN_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
PREWARM_SEMANTIC=false

# OpenRouter gateway (OpenAI-compatible client; no local generative model)
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL_NAME=mistralai/mistral-7b-instruct

CONTEXT_FUZZY_CUTOFF=75
CONTEXT_CANDIDATE_LIMIT=8
